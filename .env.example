# Copy this to .env and point at your local Postgres.
# Homebrew Postgres uses your macOS username with no password.
# Note: .env (not .env.local) — Prisma CLI only reads .env.

DATABASE_URL=postgres://cedric@localhost:5432/studio_erp
# Direct (non-pooled) connection for migrations. Locally, same as DATABASE_URL.
# On Vercel, the Postgres/Neon integration sets this one automatically.
DATABASE_URL_UNPOOLED=postgres://cedric@localhost:5432/studio_erp

# Secret used to sign the login session cookie. Any random string works.
# Optional locally (a dev fallback is used), but set it in production.
AUTH_SECRET=change-me-to-a-long-random-string
